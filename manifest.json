{
  "manifest_version": 3,
  "name": "SimpleView",
  "version": "0.1.0",
  "description": "Re-render any page as an ultra-simple, distraction-free reading view.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["<all_urls>"],
  "background": { "service_worker": "background.js" },
  "action": {
    "default_icon": { "16": "icons/icon16.png", "32": "icons/icon32.png" },
    "default_title": "Toggle SimpleView"
  },
  "options_page": "options/options.html",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": [
        "vendor/Readability-readerable.js",
        "vendor/Readability.js",
        "content/settings.js",
        "content/extract.js",
        "content/render.js",
        "content/main.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["styles/simpleview.css"],
      "matches": ["http://*/*", "https://*/*"]
    }
  ]
}
